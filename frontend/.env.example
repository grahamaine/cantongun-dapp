# CantonGun frontend — environment configuration.
# Copy to `.env` and adjust. All values are optional; defaults target a local demo.

# Ledger mode: "demo" (in-browser simulated ledger, zero dependencies)
#           or "live" (real Canton via @canton-network/wallet-sdk).
VITE_LEDGER_MODE=demo

# --- live mode only (Canton wallet SDK) -------------------------------------

# JSON Ledger API endpoint of the participant the dApp talks to.
VITE_LEDGER_CLIENT_URL=http://localhost:6201

# Optional explicit synchronizer (sync domain) id; auto-detected if omitted.
# VITE_SYNCHRONIZER_ID=

# Package id of the deployed `cantongun` DAR. Default uses the package-name alias.
# Pin an explicit hash for reproducible template ids.
VITE_CANTONGUN_PACKAGE_ID=#cantongun

# Auth (LocalNet self-signed dev issuer). OVERRIDE for any real deployment;
# never ship the unsafe secret.
VITE_AUTH_ISSUER=unsafe-auth
VITE_AUTH_CLIENT_ID=ledger-api-user
VITE_AUTH_CLIENT_SECRET=unsafe
VITE_AUTH_AUDIENCE=https://canton.network.global
VITE_AUTH_SCOPE=
